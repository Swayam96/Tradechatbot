# Flask
SECRET_KEY=change-me-in-production
FLASK_DEBUG=false
PORT=5000

# Website ingestion
TARGET_WEBSITE_BASE_URL=https://www.investopedia.com
MAX_PAGES=50
MAX_DEPTH=2
CRAWL_DELAY_SECONDS=1.0
USER_AGENT=TradeScope-AI-Bot/1.0 (+https://github.com/trade-assistant; educational)

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Embeddings (Hugging Face sentence-transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
# Cache embedding models on D: / project folder if C: drive is low on space
HF_HOME=D:\trade chat bot\.cache\huggingface

# Vector store: "pinecone" (default) or "faiss"
VECTOR_STORE_TYPE=pinecone

# Pinecone — required when VECTOR_STORE_TYPE=pinecone
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=trade-assistant
PINECONE_NAMESPACE=default
# Cloud region for index creation (used by scripts/setup_pinecone.py)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# FAISS — only used when VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=vector_store/faiss.index
FAISS_METADATA_PATH=vector_store/metadata.json

# Retrieval
TOP_K=5

# LLM provider: "openai", "anthropic", or "local"
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
API_KEY=your-openai-api-key-here

# For local LLM (Ollama, LM Studio, etc.)
# LLM_PROVIDER=local
# LLM_MODEL_NAME=llama3
# LLM_BASE_URL=http://localhost:11434/v1

LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# Protected rebuild endpoint (POST /api/rebuild-index with X-API-Key header)
REBUILD_API_KEY=your-rebuild-secret
